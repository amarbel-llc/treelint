# vim: ft=toml

# Per-repo override of the eng-root pre-merge hook. The eng-root sweatfile lists
# specific recipes (build-home-dry, validate-formatting) tailored to the
# home-manager config repo. conformist is a leaf Go tool, so it follows the
# eng-design_patterns-justfile(7) convention: the pre-merge hook is just `just`
# — the default recipe is the CI-equivalent lane. Here `default: build lint`
# builds the package and runs the conformance checks (the sandboxed file-based
# linters via lint-fmt + the working-tree git-state linters via lint-worktree).
# The [[pre-merge-skills]] (simplify, review, eng:loose-ends) are inherited from
# the eng-root sweatfile and intentionally not redeclared here.

[hooks]
pre-merge = "just"

# Per-worktree golangci-lint cache. golangci-lint's default user-global cache
# replays per-package diagnostics whose embedded absolute paths point at
# whichever worktree populated them; when that worktree is later deleted, the
# path-dependent result processors (nolint suppression, generated-file filter)
# can't read the referenced files and FAIL OPEN, leaking spurious findings into
# unrelated worktrees' lint runs. Pinning the cache inside the worktree keeps
# every cached path valid for the worktree's lifetime and dies with it.
# `just lint-go` defaults the same path when this env is absent (non-spinclass
# runs). Candidate for the eng-root sweatfile: eng#151.
#
# NB the bare [direnv] header is load-bearing: spinclass's tommy decoder only
# consumes [direnv.dotenv] when the parent table header is explicit
# (spinclass#113) — dropping it makes `sc validate` flag dotenv as unknown.
[direnv]

[direnv.dotenv]
GOLANGCI_LINT_CACHE = "$WORKTREE/.tmp/golangci-lint"
