# vim: ft=toml

# Per-repo override of the eng-root pre-merge hook. The eng-root sweatfile lists
# specific recipes (build-home-dry, validate-formatting) tailored to the
# home-manager config repo. conformist is a leaf Go tool, so it follows the
# eng-design_patterns-justfile(7) convention: the pre-merge hook is just `just`
# — the default recipe is the CI-equivalent lane. Here `default: build lint`
# builds the package and runs the conformance checks (the sandboxed file-based
# linters via lint-fmt + the working-tree git-state linters via lint-worktree).
# The [[pre-merge-skills]] (simplify, review, eng:loose-ends) are inherited from
# the eng-root sweatfile and intentionally not redeclared here.

[hooks]
pre-merge = "just"
